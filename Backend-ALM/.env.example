# Opcion 1: una sola URL de conexion (recomendada)
DATABASE_URL=postgres://usuario:password@host:5432/almacen

# Opcion 2: parametros separados (si no usas DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=almacen
DB_USER=postgres
DB_PASSWORD=postgres

# true para proveedores cloud que requieren SSL
DB_SSL=false

# Credenciales de acceso a la app
ADMIN_USER=almacenmirta
ADMIN_PASSWORD=almacen!

# Clave de sesion para firmar cookies
SESSION_SECRET=cambiar-por-clave-larga-y-segura

# Entorno de ejecucion
NODE_ENV=production
